# --- Line Ending Management ---
# Force everything to LF
* text eol=lf

# Force LF for Linux scripts and service files (Explicitly)
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf
*.sample text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.md text eol=lf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Sounds
*.wav binary
*.mp3 binary
*.ogg binary
*.m4a binary

# Archive files (Treat as binary, do not fix line endings)
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.7z binary

# --- Export Management ---
.gitattributes export-ignore
.gitignore export-ignore
.addonignore export-ignore
.github/ export-ignore
