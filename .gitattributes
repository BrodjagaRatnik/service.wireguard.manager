# --- Line Ending Management ---
# Force everything to LF
* text eol=lf

# Force LF for Linux scripts and service files (Explicitly)
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf
*.sample text eol=lf
*.txt text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary

# --- Export Management ---
.gitattributes export-ignore
.gitignore export-ignore
.addonignore export-ignore
.github/ export-ignore
