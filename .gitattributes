# --- Line Ending Management ---
# Set default behavior to normalize all text files
* text=auto

# Force LF for Linux scripts and service files
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf

# Denote binary files (prevents Git from corrupting them)
*.png binary
*.jpg binary
*.gif binary
*.ico binary

# --- Export Management (keeps these out of .zip releases) ---
.gitattributes export-ignore
.gitignore export-ignore
.addonignore export-ignore
.github/ export-ignore
